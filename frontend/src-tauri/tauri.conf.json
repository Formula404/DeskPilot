{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeskPilot",
  "version": "0.1.0",
  "identifier": "com.deskpilot.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeskPilot",
        "width": 520,
        "height": 680,
        "alwaysOnTop": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
